# 既定: テキスト判定はGit任せ、改行コードはLFに揃える。
# core.autocrlf の値に左右されず、checkout時にも作業ツリーをLFのまま保つ。
* text=auto eol=lf

# Windows 専用スクリプトはCRLFのままにしておく（.bat/.cmd/.ps1）。
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# 明示的にバイナリ扱い（差分・改行変換の対象外）。
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.ico   binary
*.pdf   binary
*.zip   binary
*.gz    binary
*.tar   binary
*.7z    binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary
*.eot   binary
*.mp3   binary
*.mp4   binary
*.mov   binary
*.wav   binary
