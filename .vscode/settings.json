{
  // Deno設定: backend/supabase/functions と backend/supabase/test ディレクトリでのみ有効
  "deno.enable": false,
  "deno.enablePaths": ["backend/supabase/functions", "backend/supabase/test"],
  "deno.lint": true,

  // エディタ共通設定
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "biomejs.biome",
  "editor.codeActionsOnSave": {
    "source.fixAll.biome": "explicit"
  },
  "editor.quickSuggestions": {
    "strings": true
  },

  // Biome設定: 各言語のデフォルトフォーマッター
  "[typescript]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[javascript]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[json]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "dart.flutterSdkPath": "frontend/mobile/.fvm/flutter_sdk"
}
